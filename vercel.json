{
  "buildCommand": "pnpm install && pnpm --filter @workspace/scenepulse build",
  "outputDirectory": "artifacts/scenepulse/dist/public",
  "installCommand": "pnpm install",
  "framework": null,
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://YOUR_RENDER_API_URL/api/:path*"
    }
  ]
}
